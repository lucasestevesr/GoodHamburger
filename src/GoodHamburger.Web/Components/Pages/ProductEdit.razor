@page "/products/{ProductId:guid}/edit"
@inject ProductsApiClient ProductsApi
@inject AuthSession Auth
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudStack Spacing="4">
    <PageHeader Eyebrow="CARDAPIO"
                Title="Editar item"
                Subtitle="Atualize os dados do item mantendo a edicao simples e organizada.">
        <Actions>
            <MudButton Href="/products" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">
                Voltar
            </MudButton>
        </Actions>
    </PageHeader>

    @if (!Auth.CanManageProducts)
    {
        <EmptyState Icon="@Icons.Material.Filled.Block"
                    Title="Acesso restrito"
                    Description="Seu perfil nao tem permissao para editar itens do cardapio."
                    AccentColor="Color.Error" />
    }
    else if (_loadingData)
    {
        <SectionCard Title="Carregando item">
            <MudStack Spacing="2">
                <MudSkeleton Height="44px" />
                <MudSkeleton Height="44px" />
                <MudSkeleton Height="120px" />
            </MudStack>
        </SectionCard>
    }
    else
    {
        <SectionCard Title="Dados do item">
            <MudForm @ref="_form">
                <MudGrid Class="form-grid">
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_request.Name" Label="Nome do item" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudNumericField @bind-Value="_request.Price" Label="Preco" Required="true" Format="N2" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="ProductCategory" @bind-Value="_request.Category" Label="Categoria">
                            <MudSelectItem T="ProductCategory" Value="ProductCategory.Burger">Sanduiche</MudSelectItem>
                            <MudSelectItem T="ProductCategory" Value="ProductCategory.Side">Acompanhamento</MudSelectItem>
                            <MudSelectItem T="ProductCategory" Value="ProductCategory.Drink">Bebida</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_request.Description" Label="Descricao" Lines="4" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" @bind-Value="_request.IsActive" Label="Disponivel para venda" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudForm>

            <MudStack Row="true" Spacing="2" Class="mt-4">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_saving" StartIcon="@Icons.Material.Filled.Save">
                    Salvar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/products">Cancelar</MudButton>
            </MudStack>
        </SectionCard>
    }
</MudStack>
