@page "/orders"
@inject OrdersApiClient OrdersApi
@inject AuthSession Auth
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="4">
    <PageHeader Eyebrow="PEDIDOS"
                Title="Pedidos"
                Subtitle="Acompanhe a fila, filtre por status e acesse o detalhe de cada pedido.">
        <Actions>
            @if (Auth.CanManageOrders)
            {
                <MudButton Href="/orders/new" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
                    Novo pedido
                </MudButton>
            }
        </Actions>
    </PageHeader>

    @if (!Auth.IsAuthenticated)
    {
        <EmptyState Icon="@Icons.Material.Filled.Lock"
                    Title="Sessao necessaria"
                    Description="Faca login para visualizar e gerenciar os pedidos."
                    ActionText="Ir para login"
                    ActionIcon="@Icons.Material.Filled.Login"
                    Href="/login" />
    }
    else if (!Auth.CanManageOrders)
    {
        <EmptyState Icon="@Icons.Material.Filled.Block"
                    Title="Acesso restrito"
                    Description="Seu perfil nao possui permissao para gerenciar pedidos."
                    AccentColor="Color.Error" />
    }
    else
    {
        <SectionCard Title="Fila de pedidos">
            <MudGrid Class="filters-grid mb-4">
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_orderNumberFilter"
                                  Label="Buscar por numero do pedido"
                                  Placeholder="Ex.: 1042"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" @bind-Value="_statusFilter" Label="Status">
                        <MudSelectItem T="string" Value="@AllStatusFilter">Todos</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Pending")">Pendente</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Processing")">Em preparo</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Completed")">Concluído</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Cancelled")">Cancelado</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_loadingData)
            {
                <MudStack Spacing="2">
                    <MudSkeleton Height="44px" />
                    <MudSkeleton Height="44px" />
                    <MudSkeleton Height="44px" />
                </MudStack>
            }
            else if (FilteredOrders.Any())
            {
                <MudTable Items="FilteredOrders" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Pedido</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Itens</MudTh>
                        <MudTh>Criado em</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh>Ações</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Pedido">
                            <MudText Typo="Typo.subtitle2">#@context.OrderNumber</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="@AdminVisuals.GetOrderStatusColor(context.Status)"
                                     Class="status-chip">
                                @AdminVisuals.TranslateOrderStatus(context.Status)
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Itens">@context.ItemCount</MudTd>
                        <MudTd DataLabel="Criado em">@AdminVisuals.FormatDate(context.CreationDate)</MudTd>
                        <MudTd DataLabel="Total">@context.Total.ToString("C")</MudTd>
                        <MudTd DataLabel="Ações">
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Href="@($"/orders/{context.Id}")" />
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => DeleteOrderAsync(context))" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <EmptyState Icon="@Icons.Material.Filled.ReceiptLong"
                            Title="Nenhum pedido encontrado"
                            Description="Ajuste os filtros ou crie um novo pedido."
                            ActionText="Criar pedido"
                            ActionIcon="@Icons.Material.Filled.Add"
                            Href="/orders/new" />
            }
        </SectionCard>
    }
</MudStack>
