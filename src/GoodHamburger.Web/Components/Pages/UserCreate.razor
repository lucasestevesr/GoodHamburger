@page "/users/new"
@inject UsersApiClient UsersApi
@inject AuthSession Auth
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudStack Spacing="4">
    <PageHeader Eyebrow="@(Auth.IsAdmin ? "Novo usuário" : "Novo atendente")"
                Subtitle="Crie uma conta com os dados essenciais e o perfil adequado.
                Admin pode criar e editar gerentes e atendentes.
                Gerentes podem criar e editar atendentes.
                Atendentes não têm acesso.">
        <Actions>
            <MudButton Href="/users" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">
                Voltar
            </MudButton>
        </Actions>
    </PageHeader>

    @if (!Auth.CanManageAttendants)
    {
        <EmptyState Icon="@Icons.Material.Filled.Block"
                    Title="Acesso restrito"
                    Description="Seu perfil não tem permissão para criar usuários."
                    AccentColor="Color.Error" />
    }
    else
    {
        <SectionCard Title="Dados da conta">
            <MudForm @ref="_form">
                <MudGrid Class="form-grid">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_formModel.Name" Label="Nome completo" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_formModel.Email" Label="E-mail" InputType="InputType.Email" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_formModel.Password" Label="Senha" InputType="InputType.Password" Required="true" />
                    </MudItem>
                    @if (Auth.IsAdmin)
                    {
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_formModel.Role" Label="Perfil">
                                @foreach (var role in IdentityRoles.All)
                                {
                                    <MudSelectItem T="string" Value="@role">@AdminVisuals.TranslateRole(role)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    }
                    <MudItem xs="12">
                        <MudSwitch T="bool" @bind-Value="_formModel.IsActive" Label="Conta ativa" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudForm>

            <MudStack Row="true" Spacing="2" Class="mt-4">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_loading" StartIcon="@Icons.Material.Filled.Save">
                    Salvar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/users">Cancelar</MudButton>
            </MudStack>
        </SectionCard>
    }
</MudStack>
